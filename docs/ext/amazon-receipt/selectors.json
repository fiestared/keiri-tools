{
  "schemaVersion": 1,
  "version": "2026-07-12.7",
  "note": "pagination(次ページ)は**実DOM未検証**(2026-07-12時点のフィクスチャがカード部分のみのため)。次へリンクが取れない場合もstartIndexのURL合成で巡回できる設計。実DOM検証済(2026-07-12・注文履歴10件)。カード=.js-order-card / 注文ID=.yohtmlc-order-id / 日付・金額は a-text-caps ラベル(注文日/合計)と直後の a-row の順序対応(labeledValue)。**キャンセル注文はDOMに金額が存在せず、請求も発生していないため索引簿から除外する** (検出語は「キャンセル済み」「注文はキャンセルされました」のみ。「返品」は通常注文の返品期限案内に現れるため誤検出源であり使わない)。サブスク注文(D01-)は注文日ラベルが無いことがある。￥0はAmazonの実表示(無料サブスク/ポイント全額充当/請求前)なので値0として採用し、理由つきで要確認にする(空欄にしない)。金額がDOMに無い注文は領収書ページで補完を試みる。",
  "orderHistory": {
    "orderCardSelectors": [
      ".js-order-card",
      ".order-card",
      ".a-box-group.order"
    ],
    "fields": {
      "orderId": {
        "type": "string",
        "candidates": [
          {
            "mode": "css",
            "selector": ".yohtmlc-order-id",
            "attr": "text",
            "regex": "(D?[0-9]{2,3}-[0-9]{7}-[0-9]{7})"
          },
          {
            "mode": "css",
            "selector": "a[href*='orderID=']",
            "attr": "href",
            "regex": "orderID=(D?[0-9]{2,3}-[0-9]{7}-[0-9]{7})"
          },
          {
            "mode": "cardText",
            "regex": "注文番号[\\s\\S]{0,20}?(D?[0-9]{2,3}-[0-9]{7}-[0-9]{7})"
          }
        ]
      },
      "orderDate": {
        "type": "dateJp",
        "candidates": [
          {
            "mode": "labeledValue",
            "label": "注文日",
            "regex": "([0-9]{4})年\\s*([0-9]{1,2})月\\s*([0-9]{1,2})日"
          },
          {
            "mode": "cardText",
            "regex": "注文日[\\s\\S]{0,30}?([0-9]{4})年\\s*([0-9]{1,2})月\\s*([0-9]{1,2})日"
          }
        ]
      },
      "total": {
        "type": "yen",
        "rejectZero": false,
        "candidates": [
          {
            "mode": "labeledValue",
            "label": "合計",
            "regex": "[￥¥]\\s*([0-9,]+)"
          },
          {
            "mode": "cardText",
            "regex": "合計[\\s\\S]{0,40}?[￥¥]\\s*([0-9,]+)"
          }
        ]
      },
      "seller": {
        "type": "string",
        "optional": true,
        "candidates": [
          {
            "_comment": "要素側に「販売: 」ラベルが入っている場合があるので必ず剥がす。剥がさないと索引簿の取引先が『販売: サンプル紙業』になる。ラベルが無い形にも当たるよう前置きは任意",
            "mode": "css",
            "selector": ".yohtmlc-seller-name",
            "attr": "text",
            "regex": "^\\s*(?:販売[:：]\\s*)?([^\\n]{1,60}?)\\s*$"
          },
          {
            "mode": "cardText",
            "regex": "販売[:：]\\s*([^\\n]{1,60})"
          }
        ]
      },
      "firstItemTitle": {
        "type": "string",
        "optional": true,
        "candidates": [
          {
            "mode": "css",
            "selector": ".yohtmlc-product-title",
            "attr": "text"
          },
          {
            "mode": "css",
            "selector": ".a-fixed-left-grid-col.a-col-right a.a-link-normal",
            "attr": "text"
          }
        ]
      },
      "cancelled": {
        "type": "string",
        "optional": true,
        "candidates": [
          {
            "mode": "cardText",
            "regex": "(キャンセル済み|注文はキャンセルされました|この注文の請求は行われていません)"
          }
        ]
      }
    },
    "pagination": {
      "nextLinkSelectors": [
        "ul.a-pagination li.a-last:not(.a-disabled) > a",
        ".a-pagination .a-last a",
        "a.a-last[href]"
      ],
      "nextLinkTexts": [
        "次へ",
        "Next"
      ],
      "startIndexParam": "startIndex",
      "pageSize": 10,
      "maxPages": 30
    }
  },
  "receipt": {
    "urlTemplates": {
      "physical": "https://www.amazon.co.jp/gp/css/summary/print.html?ie=UTF8&orderID={orderId}",
      "digital": "https://www.amazon.co.jp/gp/digital/your-account/order-summary.html?ie=UTF8&orderID={orderId}&print=1"
    },
    "digitalOrderIdPrefix": "D",
    "fields": {
      "total": {
        "type": "yen",
        "rejectZero": false,
        "candidates": [
          {
            "mode": "cardText",
            "regex": "注文合計[\\s\\S]{0,60}?[￥¥]\\s*([0-9,]+)"
          },
          {
            "mode": "cardText",
            "regex": "ご請求額[\\s\\S]{0,60}?[￥¥]\\s*([0-9,]+)"
          },
          {
            "mode": "cardText",
            "regex": "合計[\\s\\S]{0,60}?[￥¥]\\s*([0-9,]+)"
          },
          {
            "mode": "cardText",
            "regex": "Grand Total[\\s\\S]{0,60}?[￥¥]\\s*([0-9,]+)"
          }
        ]
      },
      "orderDate": {
        "type": "dateJp",
        "candidates": [
          {
            "mode": "cardText",
            "regex": "注文日[\\s\\S]{0,30}?([0-9]{4})年\\s*([0-9]{1,2})月\\s*([0-9]{1,2})日"
          },
          {
            "mode": "cardText",
            "regex": "デジタル注文[:：\\s]*([0-9]{4})年\\s*([0-9]{1,2})月\\s*([0-9]{1,2})日"
          }
        ]
      }
    }
  }
}
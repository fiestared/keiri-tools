{
  "schemaVersion": 1,
  "version": "2026-07-12.3",
  "note": "実DOM検証済(2026-07-12・注文履歴10件)。確定事項: カードは .js-order-card、注文IDは .yohtmlc-order-id、日付と金額は a-text-caps ラベル(注文日/合計)と直後の a-row の値の対応で取る(labeledValueモード)。**重要: 注文履歴ページに金額が存在しない注文がある(実測10件中3件はDOMに￥表記ゼロ)。この場合は領収書ページをfetchして補完する(receipt.fields)**。サブスク注文(D01-)には注文日ラベルが無いことがある。リモート版は https://keiri-tools.com/ext/amazon-receipt/selectors.json",
  "orderHistory": {
    "orderCardSelectors": [
      ".js-order-card",
      ".order-card",
      ".a-box-group.order"
    ],
    "fields": {
      "orderId": {
        "type": "string",
        "candidates": [
          {
            "mode": "css",
            "selector": ".yohtmlc-order-id",
            "attr": "text",
            "regex": "(D?[0-9]{2,3}-[0-9]{7}-[0-9]{7})"
          },
          {
            "mode": "css",
            "selector": "a[href*='orderID=']",
            "attr": "href",
            "regex": "orderID=(D?[0-9]{2,3}-[0-9]{7}-[0-9]{7})"
          },
          {
            "mode": "cardText",
            "regex": "注文番号[\\s\\S]{0,20}?(D?[0-9]{2,3}-[0-9]{7}-[0-9]{7})"
          }
        ]
      },
      "orderDate": {
        "type": "dateJp",
        "candidates": [
          {
            "mode": "labeledValue",
            "label": "注文日",
            "regex": "([0-9]{4})年\\s*([0-9]{1,2})月\\s*([0-9]{1,2})日"
          },
          {
            "mode": "cardText",
            "regex": "注文日[\\s\\S]{0,30}?([0-9]{4})年\\s*([0-9]{1,2})月\\s*([0-9]{1,2})日"
          }
        ]
      },
      "total": {
        "type": "yen",
        "rejectZero": true,
        "candidates": [
          {
            "mode": "labeledValue",
            "label": "合計",
            "regex": "[￥¥]\\s*([0-9,]+)"
          },
          {
            "mode": "cardText",
            "regex": "合計[\\s\\S]{0,40}?[￥¥]\\s*([0-9,]+)"
          }
        ]
      },
      "seller": {
        "type": "string",
        "optional": true,
        "candidates": [
          {
            "mode": "css",
            "selector": ".yohtmlc-seller-name",
            "attr": "text"
          },
          {
            "mode": "cardText",
            "regex": "販売[:：]\\s*([^\\n]{1,60})"
          }
        ]
      },
      "firstItemTitle": {
        "type": "string",
        "optional": true,
        "candidates": [
          {
            "mode": "css",
            "selector": ".yohtmlc-product-title",
            "attr": "text"
          },
          {
            "mode": "css",
            "selector": ".a-fixed-left-grid-col.a-col-right a.a-link-normal",
            "attr": "text"
          }
        ]
      }
    },
    "paginationNextSelectors": [
      "ul.a-pagination li.a-last a"
    ]
  },
  "receipt": {
    "urlTemplates": {
      "physical": "https://www.amazon.co.jp/gp/css/summary/print.html?ie=UTF8&orderID={orderId}",
      "digital": "https://www.amazon.co.jp/gp/digital/your-account/order-summary.html?ie=UTF8&orderID={orderId}&print=1"
    },
    "digitalOrderIdPrefix": "D",
    "fields": {
      "total": {
        "type": "yen",
        "rejectZero": false,
        "candidates": [
          {
            "mode": "cardText",
            "regex": "注文合計[\\s\\S]{0,60}?[￥¥]\\s*([0-9,]+)"
          },
          {
            "mode": "cardText",
            "regex": "ご請求額[\\s\\S]{0,60}?[￥¥]\\s*([0-9,]+)"
          },
          {
            "mode": "cardText",
            "regex": "合計[\\s\\S]{0,60}?[￥¥]\\s*([0-9,]+)"
          },
          {
            "mode": "cardText",
            "regex": "Grand Total[\\s\\S]{0,60}?[￥¥]\\s*([0-9,]+)"
          }
        ]
      },
      "orderDate": {
        "type": "dateJp",
        "candidates": [
          {
            "mode": "cardText",
            "regex": "注文日[\\s\\S]{0,30}?([0-9]{4})年\\s*([0-9]{1,2})月\\s*([0-9]{1,2})日"
          },
          {
            "mode": "cardText",
            "regex": "デジタル注文[:：\\s]*([0-9]{4})年\\s*([0-9]{1,2})月\\s*([0-9]{1,2})日"
          }
        ]
      }
    }
  }
}